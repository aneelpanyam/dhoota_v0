# Supabase — Get from: https://supabase.com/dashboard/project/_/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SECRET_KEY=sb_secret_your-key

# AWS S3 — See docs/AWS_SETUP.md for step-by-step guide
# Create a dedicated IAM user with least-privilege S3 access
AWS_S3_BUCKET=dhoota-media-dev
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIA_your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# OpenAI — Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# AWS CloudWatch Logs — Structured server-side logging
# Uses the same AWS credentials as S3 above (IAM user needs cloudwatch-logs permissions)
CLOUDWATCH_ENABLED=false
CLOUDWATCH_LOG_GROUP=/dhoota/pipeline
CLOUDWATCH_REGION=ap-south-1

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public site mode — NEXT_PUBLIC_ required for middleware (Edge runtime)
NEXT_PUBLIC_DHOOTA_PUBLIC_MODE=false
NEXT_PUBLIC_DHOOTA_PUBLIC_TENANT_ID=
NEXT_PUBLIC_DHOOTA_PUBLIC_USER_ID=

# Debug panel — Shows pipeline traces (SQL, LLM). When enabled, visible in both authenticated and public views. Default: false.
# NEXT_PUBLIC_DHOOTA_DEBUG_PANEL=false
